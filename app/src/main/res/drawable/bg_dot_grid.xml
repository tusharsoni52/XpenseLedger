    <path android:pathData="M6,4.5 L7.5,6 L6,7.5 L4.5,6 Z"   android:fillColor="#1A00D4A0" />
    <path android:pathData="M18,4.5 L19.5,6 L18,7.5 L16.5,6 Z" android:fillColor="#1200D4A0" />
    <path android:pathData="M30,4.5 L31.5,6 L30,7.5 L28.5,6 Z" android:fillColor="#1A00D4A0" />
    <path android:pathData="M42,4.5 L43.5,6 L42,7.5 L40.5,6 Z" android:fillColor="#1200D4A0" />
    <!-- Row 2 -->
