<?xml version="1.0" encoding="utf-8"?>
<!--
    Subtle dot-grid pattern for the financial dashboard (Home) background.
    Each dot is a small diamond shape drawn with path commands (VectorDrawable
    does not support SVG arc shortcuts).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="48dp"
    android:height="48dp"
    android:viewportWidth="48"
    android:viewportHeight="48">

    <!-- 4x4 dot grid at 12dp spacing, each dot is a 2x2 diamond -->
