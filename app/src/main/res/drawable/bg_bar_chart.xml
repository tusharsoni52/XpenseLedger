<?xml version="1.0" encoding="utf-8"?>
<!--
    Stylised bar-chart silhouette used as a decorative element on the
    Compare / Analytics screen background. Semi-transparent bars suggest
    a financial chart without being distracting.
    All bars are drawn with M/L/Z path commands — no SVG <rect> tags.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="160dp"
    android:height="100dp"
    android:viewportWidth="160"
    android:viewportHeight="100">

    <!-- Baseline -->
    <path
        android:pathData="M8,90 L152,90"
        android:strokeColor="#1A00D4A0"
        android:strokeWidth="1"
        android:fillColor="#00000000" />

    <!-- Bar 1 x=12 y=70 w=14 h=20 -->
    <path android:pathData="M12,70 L26,70 L26,90 L12,90 Z"
        android:fillColor="#1A7B68EE" android:strokeColor="#00000000" />
    <!-- Bar 2 x=32 y=55 w=14 h=35 -->
    <path android:pathData="M32,55 L46,55 L46,90 L32,90 Z"
        android:fillColor="#2000D4A0" android:strokeColor="#00000000" />
    <!-- Bar 3 x=52 y=35 w=14 h=55 -->
    <path android:pathData="M52,35 L66,35 L66,90 L52,90 Z"
        android:fillColor="#2500D4A0" android:strokeColor="#00000000" />
    <!-- Bar 4 x=72 y=45 w=14 h=45 -->
    <path android:pathData="M72,45 L86,45 L86,90 L72,90 Z"
        android:fillColor="#1A7B68EE" android:strokeColor="#00000000" />
    <!-- Bar 5 x=92 y=62 w=14 h=28 -->
    <path android:pathData="M92,62 L106,62 L106,90 L92,90 Z"
        android:fillColor="#2000D4A0" android:strokeColor="#00000000" />
    <!-- Bar 6 x=112 y=25 w=14 h=65 -->
    <path android:pathData="M112,25 L126,25 L126,90 L112,90 Z"
        android:fillColor="#2A00D4A0" android:strokeColor="#00000000" />
    <!-- Bar 7 x=132 y=50 w=14 h=40 -->
    <path android:pathData="M132,50 L146,50 L146,90 L132,90 Z"
        android:fillColor="#1A7B68EE" android:strokeColor="#00000000" />

    <!-- Subtle trend line over the bars -->
    <path
        android:pathData="M19,68 L39,52 L59,33 L79,43 L99,60 L119,23 L139,48"
        android:strokeColor="#2000D4A0"
        android:strokeWidth="1.5"
        android:fillColor="#00000000"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Dots at each data point (diamond shape using path) -->
    <path android:pathData="M19,65.5 L21.5,68 L19,70.5 L16.5,68 Z" android:fillColor="#3000D4A0" />
    <path android:pathData="M39,49.5 L41.5,52 L39,54.5 L36.5,52 Z" android:fillColor="#3000D4A0" />
    <path android:pathData="M59,30.5 L61.5,33 L59,35.5 L56.5,33 Z" android:fillColor="#3000D4A0" />
    <path android:pathData="M79,40.5 L81.5,43 L79,45.5 L76.5,43 Z" android:fillColor="#3000D4A0" />
    <path android:pathData="M99,57.5 L101.5,60 L99,62.5 L96.5,60 Z" android:fillColor="#3000D4A0" />
    <path android:pathData="M119,20.5 L121.5,23 L119,25.5 L116.5,23 Z" android:fillColor="#3000D4A0" />
    <path android:pathData="M139,45.5 L141.5,48 L139,50.5 L136.5,48 Z" android:fillColor="#3000D4A0" />
</vector>
